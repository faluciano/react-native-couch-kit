{
  "name": "couch-kit",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "bun run --filter '@couch-kit/core' build && bun run --filter '@couch-kit/client' build && bun run --filter '@couch-kit/host' --filter '@couch-kit/cli' --filter '@couch-kit/devtools' build",
    "test": "bun run --filter './packages/*' test",
    "lint": "bun run --filter '*' lint",
    "typecheck": "bun run --filter '@couch-kit/core' typecheck && bun run --filter '*' typecheck",
    "clean": "bun run --filter '*' clean",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "bun run scripts/publish.ts",
    "lint:changesets": "bun run scripts/lint-changeset-headers.ts",
    "docs": "typedoc",
    "docs:llms": "bun run scripts/generate-llms-txt.ts",
    "size": "size-limit"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.2",
    "@changesets/cli": "^2.29.8",
    "@size-limit/file": "^11.0.0",
    "@types/bun": "^1.3.9",
    "@types/react": "^19.1.1",
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "typescript-eslint": "^8.0.0",
    "prettier": "^3.8.1",
    "size-limit": "^11.0.0",
    "typedoc": "^0.27.0",
    "typescript": "^5.9.3"
  },
  "packageManager": "bun@1.2.19",
  "engines": {
    "node": ">=18.0.0"
  },
  "overrides": {
    "fast-xml-parser": "5.3.5"
  },
  "size-limit": [
    {
      "path": "packages/core/dist/index.js",
      "limit": "10 KB"
    },
    {
      "path": "packages/client/dist/index.js",
      "limit": "15 KB"
    },
    {
      "path": "packages/devtools/dist/index.js",
      "limit": "15 KB"
    }
  ]
}
